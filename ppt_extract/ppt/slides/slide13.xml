49"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/></p:spPr><p:txBody><a:bodyPr wrap="square" rtlCol="0"><a:spAutoFit/></a:bodyPr><a:lstStyle/><a:p><a:pPr algn="just"><a:lnSpc><a:spcPct val="200000"/></a:lnSpc></a:pPr><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1600" b="1" dirty="0"/><a:t>        我的妈妈对食物这么这么用心，她说这是因为</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1600" b="1" dirty="0"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t>她非常非常爱我们</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1600" b="1" dirty="0"/><a:t>。每次做饭，她都会花好长时间，看看书，或者问问别人，怎么做食物才好吃又有营养。她想让我们的身体都棒棒的，也希望我们的家充满欢声笑语。每次看到我们吃得开心，妈妈就会笑得很甜。妈妈，谢谢您，</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1600" b="1" dirty="0"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill></a:rPr><a:t>我们也好爱好爱您</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1600" b="1" dirty="0"/><a:t>！</a:t></a:r><a:endParaRPr lang="zh-CN" altLang="zh-CN" sz="1600" b="1" dirty="0"/></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="3" name="矩形 2"/><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="3827572" y="373580"/><a:ext cx="4830445" cy="521970"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr><p:txBody><a:bodyPr wrap="none"><a:spAutoFit/></a:bodyPr><a:lstStyle/><a:p><a:pPr lvl="0" algn="ctr" defTabSz="914400"><a:defRPr/></a:pPr><a:r><a:rPr lang="zh-CN" sz="2800" b="1" dirty="0"><a:gradFill><a:gsLst><a:gs pos="0"><a:schemeClr val="bg1"/></a:gs><a:gs pos="89000"><a:srgbClr val="6BDBFA"/></a:gs></a:gsLst><a:lin ang="5400000" scaled="1"/></a:gradFill><a:latin typeface="思源黑体 CN Heavy" panose="020B0A00000000000000" charset="-122"/><a:ea typeface="思源黑体 CN Heavy" panose="020B0A00000000000000" charset="-122"/><a:cs typeface="阿里巴巴普惠体 B" panose="00020600040101010101" pitchFamily="18" charset="-122"/></a:rPr><a:t>如何生动、具体描写一个人？</a:t></a:r></a:p></p:txBody></p:sp></p:spTree></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr><mc:AlternateContent xmlns