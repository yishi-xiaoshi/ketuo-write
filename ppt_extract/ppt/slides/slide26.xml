SzTx/><a:buFont typeface="Wingdings" panose="05000000000000000000" pitchFamily="2" charset="2"/><a:buNone/><a:defRPr/></a:pPr><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200" b="1" dirty="0"><a:solidFill><a:srgbClr val="000000"/></a:solidFill><a:latin typeface="微软雅黑" panose="020B0503020204020204" charset="-122"/><a:ea typeface="微软雅黑" panose="020B0503020204020204" charset="-122"/><a:sym typeface="+mn-ea"/></a:rPr><a:t>议论文：</a:t></a:r><a:endParaRPr lang="en-US" altLang="zh-CN" sz="1200" dirty="0"><a:solidFill><a:srgbClr val="000000"/></a:solidFill><a:latin typeface="微软雅黑" panose="020B0503020204020204" charset="-122"/><a:ea typeface="微软雅黑" panose="020B0503020204020204" charset="-122"/><a:sym typeface="+mn-ea"/></a:endParaRPr></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>观点明确</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：文章开头明确提出论点。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>论据充分</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：用事实、数据、理论等支持论点。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>逻辑严密</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：论证过程条理清晰，逻辑性强。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>论证方法多样</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：包括举例、对比、因果分析等。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>语言精炼</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：表达准确，避免冗长。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>反驳有力</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：针对反方观点进行有力反驳。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>结构严谨</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：通常包括引论、本论、结论三部分。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>问题导向</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：围绕问题展开论述，解决问题。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>针对性强</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：针对特定问题或现象发表看法。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>说服力强</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：通过论证使读者信服。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>层次分明</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：论点、论据、论证层次分明。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>引用权威</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：引用权威观点或数据增强说服力。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>对比论证</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：通过对比不同观点或现象加强论证。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>因果分析</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：分析现象背后的原因和结果。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>归纳与演绎</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：运用归纳法和演绎法进行论证。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>提出解决方案</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：针对问题提出切实可行的解决方案。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>语言严谨</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：避免使用模糊、不确定的词汇。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>反思与批判</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：对既有观点进行反思和批判。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>联系实际</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：结合实际情况进行论述。</a:t></a:r></a:p><a:p><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" b="1" dirty="0"/><a:t>引导思考</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1000" dirty="0"/><a:t>：激发读者对问题的深入思考和讨论。</a:t></a:r></a:p></p:txBody></p:sp><p:graphicFrame><p:nvGraphicFramePr><p:cNvPr id="3" name="表格 2"/><p:cNvGraphicFramePr><a:graphicFrameLocks noGrp="1"/></p:cNvGraphicFramePr><p:nvPr/></p:nvGraphicFramePr><p:xfrm><a:off x="4823013" y="1759571"/><a:ext cx="4097020" cy="2133600"/></p:xfrm><a:graphic><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/table"><a:tbl><a:tblPr firstRow="1" bandRow="1"><a:tableStyleId>{5C22544A-7EE6-4342-B048-85BDC9FD1C3A}</a:tableStyleId></a:tblPr><a:tblGrid><a:gridCol w="780357"><a:extLst><a:ext uri="{9D8B030D-6E8A-4147-A177-3AD203B41FA5}"><a16:colId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" val="20000"/></a:ext></a:extLst></a:gridCol><a:gridCol w="913971"><a:extLst><a:ext uri="{9D8B030D-6E8A-4147-A177-3AD203B41FA5}"><a16:colId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" val="20001"/></a:ext></a:extLst></a:gridCol><a:gridCol w="2402542"><a:extLst><a:ext uri="{9D8B030D-6E8A-4147-A177-3AD203B41FA5}"><a16:colId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" val="20002"/></a:ext></a:extLst></a:gridCol></a:tblGrid><a:tr h="200931"><a:tc><a:txBody><a:bodyPr/><a:lstStyle/><a:p><a:pPr algn="ctr"/><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1400" dirty="0"/><a:t>对象</a:t></a:r></a:p></a:txBody><a:tcPr/></a:tc><a:tc><a:txBody><a:bodyPr/><a:lstStyle/><a:p><a:pPr algn="ctr"/><a:r